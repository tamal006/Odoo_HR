# --- Required always ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Phase 2: Agent layer config ---
# Role for testing (employee | admin). In production this comes from the
# authenticated session, not from .env.
DEFAULT_ROLE=admin
DEFAULT_EMPLOYEE_ID=3
DEFAULT_EMPLOYEE_NAME=Priya Nair

# MCP server target: path to a .py script, "odoo" for the real server,
# or any shell command. Defaults to mock_odoo_mcp_server.py.
MCP_SERVER_TARGET=mock_odoo_mcp_server.py

# --- Only needed once you run against the real mcp-server-odoo ---
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your-database-name

# Auth: EITHER an API key...
ODOO_API_KEY=
# ...OR username/password (fill both if not using ODOO_API_KEY)
ODOO_USER=
ODOO_PASSWORD=

# YOLO mode — bypasses Odoo's own MCP permission checks entirely.
# Use "read" while sanity-checking the connection (safe: blocks all writes).
# Only switch to "true" once the system prompt / role-restriction safety
# layer is in place — with YOLO=true there is no other safety net.
ODOO_YOLO=read

# Leave this off unless you specifically need call_model_method.
ODOO_MCP_ENABLE_METHOD_CALLS=false
